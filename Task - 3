<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>StudyGenie | Login to Your AI Study Assistant</title>
  <!-- Google Fonts + modern font stack -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
  <!-- Font Awesome 6 (free icons) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: linear-gradient(135deg, #f5f7ff 0%, #e9eefc 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      position: relative;
    }

    /* subtle animated background elements */
    body::before {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: radial-gradient(circle at 10% 20%, rgba(108, 43, 217, 0.08), transparent 70%);
      pointer-events: none;
      z-index: 0;
    }

    /* main login card container */
    .login-container {
      width: 100%;
      max-width: 460px;
      margin: 0 auto;
      position: relative;
      z-index: 2;
      animation: fadeInUp 0.5s ease-out;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* modern glassmorphic card */
    .login-card {
      background: rgba(255, 255, 255, 0.96);
      backdrop-filter: blur(2px);
      border-radius: 48px;
      padding: 2.5rem 2rem;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(108, 43, 217, 0.1);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .login-card:hover {
      box-shadow: 0 30px 55px -12px rgba(58, 12, 163, 0.2);
    }

    /* brand header */
    .brand-header {
      text-align: center;
      margin-bottom: 2rem;
    }

    .logo {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: 1.8rem;
      font-weight: 800;
      background: linear-gradient(135deg, #3A0CA3, #6C2BD9);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      text-decoration: none;
      margin-bottom: 0.75rem;
    }

    .logo i {
      background: linear-gradient(135deg, #6C2BD9, #3A0CA3);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      font-size: 2rem;
    }

    .brand-header h2 {
      font-size: 1.9rem;
      font-weight: 700;
      color: #0f172a;
      margin-top: 0.25rem;
    }

    .brand-header p {
      color: #5b6e8c;
      font-size: 0.95rem;
      margin-top: 0.5rem;
    }

    /* form group styling */
    .input-group {
      margin-bottom: 1.5rem;
    }

    .input-label {
      display: block;
      font-weight: 600;
      font-size: 0.85rem;
      margin-bottom: 0.5rem;
      color: #1e293b;
      letter-spacing: -0.2px;
    }

    .input-field {
      width: 100%;
      padding: 0.9rem 1rem 0.9rem 2.8rem;
      font-size: 1rem;
      font-family: 'Inter', sans-serif;
      border: 1.5px solid #e2e8f0;
      border-radius: 28px;
      background: #ffffff;
      transition: all 0.2s ease;
      outline: none;
      color: #0f172a;
    }

    .input-field:focus {
      border-color: #6C2BD9;
      box-shadow: 0 0 0 4px rgba(108, 43, 217, 0.15);
    }

    /* icon inside input */
    .input-icon {
      position: relative;
    }

    .input-icon i {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: #94a3b8;
      font-size: 1.1rem;
      pointer-events: none;
      transition: color 0.2s;
    }

    .input-field:focus + i {
      color: #6C2BD9;
    }

    /* forgot password row */
    .forgot-row {
      text-align: right;
      margin: -0.5rem 0 1.5rem 0;
    }

    .forgot-link {
      font-size: 0.85rem;
      color: #6C2BD9;
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s;
    }

    .forgot-link:hover {
      color: #3A0CA3;
      text-decoration: underline;
    }

    /* login button */
    .login-btn {
      width: 100%;
      background: linear-gradient(135deg, #6C2BD9, #3A0CA3);
      color: white;
      border: none;
      padding: 0.9rem;
      font-size: 1rem;
      font-weight: 700;
      border-radius: 40px;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.2, 0.9, 0.4, 1.1);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      box-shadow: 0 10px 20px -5px rgba(108, 43, 217, 0.3);
    }

    .login-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 18px 28px -8px rgba(108, 43, 217, 0.4);
      background: linear-gradient(135deg, #7e3af2, #4b12c2);
    }

    .login-btn:active {
      transform: translateY(1px);
    }

    /* divider / alternative login */
    .divider {
      display: flex;
      align-items: center;
      text-align: center;
      margin: 1.8rem 0 1.5rem;
    }

    .divider::before,
    .divider::after {
      content: '';
      flex: 1;
      border-bottom: 1px solid #e2e8f0;
    }

    .divider span {
      padding: 0 0.8rem;
      color: #7c8ba0;
      font-size: 0.8rem;
      font-weight: 500;
    }

    /* social login icons */
    .social-login {
      display: flex;
      justify-content: center;
      gap: 1rem;
      margin-top: 0.5rem;
    }

    .social-icon {
      background: #f1f5f9;
      width: 46px;
      height: 46px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 40px;
      color: #334155;
      font-size: 1.3rem;
      transition: all 0.2s ease;
      text-decoration: none;
    }

    .social-icon:hover {
      background: #e9eefc;
      transform: translateY(-3px);
      color: #3A0CA3;
      box-shadow: 0 6px 12px -6px rgba(0,0,0,0.1);
    }

    /* sign up link */
    .signup-prompt {
      text-align: center;
      margin-top: 2rem;
      font-size: 0.9rem;
      color: #475569;
    }

    .signup-link {
      color: #6C2BD9;
      text-decoration: none;
      font-weight: 700;
      margin-left: 4px;
    }

    .signup-link:hover {
      text-decoration: underline;
    }

    /* extra decorative shape */
    .decor-blob {
      position: fixed;
      bottom: -10%;
      right: -5%;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(108,43,217,0.12) 0%, rgba(58,12,163,0.02) 80%);
      border-radius: 50%;
      pointer-events: none;
      z-index: 0;
    }

    /* responsive adjustments */
    @media (max-width: 520px) {
      .login-card {
        padding: 1.8rem 1.5rem;
        border-radius: 36px;
      }
      .brand-header h2 {
        font-size: 1.6rem;
      }
      .input-field {
        padding: 0.8rem 1rem 0.8rem 2.5rem;
      }
      .social-icon {
        width: 42px;
        height: 42px;
        font-size: 1.2rem;
      }
    }

    /* subtle animation for demo */
    @keyframes gentlePulse {
      0% { opacity: 0.6; }
      100% { opacity: 1; }
    }
  </style>
</head>
<body>
  <div class="login-container">
    <div class="login-card">
      <div class="brand-header">
        <a href="#" class="logo">
          <i class="fas fa-brain"></i> 
          <span>StudyGenie</span>
        </a>
        <h2>Welcome back</h2>
        <p>Sign in to continue your AI-powered learning journey</p>
      </div>

      <!-- Login Form -->
      <form id="loginForm" action="#" method="POST">
        <!-- Email Field -->
        <div class="input-group">
          <label class="input-label" for="email">Email address</label>
          <div class="input-icon">
            <input type="email" id="email" name="email" class="input-field" placeholder="student@example.com" required autocomplete="email">
            <i class="fas fa-envelope"></i>
          </div>
        </div>

        <!-- Password Field -->
        <div class="input-group">
          <label class="input-label" for="password">Password</label>
          <div class="input-icon">
            <input type="password" id="password" name="password" class="input-field" placeholder="••••••••" required autocomplete="current-password">
            <i class="fas fa-lock"></i>
          </div>
        </div>

        <!-- Forgot Password -->
        <div class="forgot-row">
          <a href="#" class="forgot-link">Forgot password?</a>
        </div>

        <!-- Login Button -->
        <button type="submit" class="login-btn">
          <i class="fas fa-arrow-right-to-bracket"></i> Log in
        </button>

        <!-- Divider -->
        <div class="divider">
          <span>or continue with</span>
        </div>

        <!-- Social Login (optional but adds modern feel) -->
        <div class="social-login">
          <a href="#" class="social-icon" aria-label="Google login">
            <i class="fab fa-google"></i>
          </a>
          <a href="#" class="social-icon" aria-label="Apple login">
            <i class="fab fa-apple"></i>
          </a>
          <a href="#" class="social-icon" aria-label="Microsoft login">
            <i class="fab fa-microsoft"></i>
          </a>
          <a href="#" class="social-icon" aria-label="GitHub login">
            <i class="fab fa-github"></i>
          </a>
        </div>

        <div class="signup-prompt">
          Don't have an account?
          <a href="#" class="signup-link">Get started for free →</a>
        </div>
      </form>
    </div>
  </div>
  <div class="decor-blob"></div>

  <!-- optional: minimal prevent default to avoid page reload (just for demo polish) -->
  <script>
    (function() {
      const form = document.getElementById('loginForm');
      if (form) {
        form.addEventListener('submit', function(e) {
          e.preventDefault();
          // Just for UI demonstration — in real integration you'd handle auth.
          const email = document.getElementById('email').value.trim();
          const pwd = document.getElementById('password').value;
          if (email === "" || pwd === "") {
            alert("Please fill in both email and password to log in.");
          } else {
            alert(`Welcome back, ${email}! (Demo login — great UI ready for backend.)`);
            // you could redirect or perform API calls
          }
        });
      }
      // optional interactive demo for forgot password
      const forgotLink = document.querySelector('.forgot-link');
      if (forgotLink) {
        forgotLink.addEventListener('click', function(e) {
          e.preventDefault();
          alert("🔐 Password reset link would be sent to your email. (Demo interaction)");
        });
      }
    })();
  </script>
</body>
</html>
