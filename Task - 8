                  </div>
                  <div class="mt-3">
                    <div class="flex justify-between text-sm mb-1">
                      <span>Course Progress</span>
                      <span>${Math.round(course.progress || 0)}%</span>
                    </div>
                    <div class="progress-bar">
                      <div class="progress-fill" style="width: ${course.progress || 0}%"></div>
                    </div>
                  </div>
                </div>
              `).join('')
            }
          </div>
          
          <div>
            <h2 class="text-2xl font-semibold mb-4">Recommended for You</h2>
            ${availableCourses.slice(0, 3).map(course => `
              <div class="glass-card p-4 mb-3" onclick="selectCourse('${course.id}')" style="cursor:pointer">
                <h4 class="font-semibold">${course.title}</h4>
                <p class="text-sm text-gray-600">₹${course.price}</p>
                <button class="btn btn-primary text-sm mt-2 px-4 py-2" onclick="event.stopPropagation();enrollInCourse('${course.id}')">Enroll</button>
              </div>
            `).join('')}
            
            <div class="glass-card p-6 mt-4 bg-gradient-to-r from-purple-50 to-blue-50">
              <h3 class="font-bold mb-2">Learning Stats</h3>
              <p class="text-2xl font-bold text-purple-600">${enrolledCoursesData.length}</p>
              <p class="text-sm text-gray-600">Courses Enrolled</p>
              <hr class="my-3">
              <p class="text-sm">Total Progress: ${Math.round(enrolledCoursesData.reduce((sum, c) => sum + (c.progress || 0), 0) / (enrolledCoursesData.length || 1))}%</p>
            </div>
          </div>
        </div>
      </div>
    `;
    
    document.getElementById('root').innerHTML = wrapWithNav(html, user);
  }

  function renderCourseDetails(course, user) {
    const isEnrolled = user?.enrolledCourses?.some(e => e.courseId === course.id);
    
    const html = `
      <div class="container mx-auto px-4 py-8">
        <button onclick="navigateTo('dashboard')" class="text-purple-600 mb-4 flex items-center gap-2">
          <i class="fas fa-arrow-left"></i> Back to Dashboard
        </button>
        
        <div class="grid lg:grid-cols-3 gap-8">
          <div class="lg:col-span-2">
            <div class="glass-card p-6 mb-6">
              <h1 class="text-3xl font-bold mb-4">${course.title}</h1>
              <p class="text-gray-700 mb-4">${course.description}</p>
              <div class="flex gap-4 text-sm text-gray-600">
                <span><i class="fas fa-user"></i> ${course.instructor}</span>
                <span><i class="fas fa-clock"></i> ${course.duration}</span>
                <span><i class="fas fa-signal"></i> ${course.level}</span>
                <span><i class="fas fa-tag"></i> ${course.category}</span>
              </div>
            </div>
            
            <div class="glass-card p-6">
              <h2 class="text-2xl font-semibold mb-4">Course Curriculum</h2>
              ${course.modules.map((module, idx) => `
                <div class="mb-4">
                  <h3 class="font-semibold text-lg mb-2">Module ${idx + 1}: ${module.title}</h3>
                  <div class="pl-4">
                    ${module.lessons.map(lesson => `
                      <div class="flex items-center gap-3 py-2 border-b border-gray-100">
                        <i class="fas fa-play-circle text-purple-600"></i>
                        <span>${lesson.title}</span>
                        <span class="text-sm text-gray-500 ml-auto">${lesson.duration}</span>
                      </div>
                    `).join('')}
                  </div>
                </div>
              `).join('')}
            </div>
          </div>
          
          <div>
            <div class="glass-card p-6 text-center sticky top-24">
              <div class="text-4xl font-bold text-purple-600 mb-4">₹${course.price}</div>
              ${isEnrolled ? 
                `<button onclick="continueLearning('${course.id}')" class="btn btn-primary w-full">Continue Learning</button>
                 <p class="text-green-600 mt-3"><i class="fas fa-check-circle"></i> You're enrolled!</p>` :
                `<button onclick="enrollInCourse('${course.id}')" class="btn btn-primary w-full">Enroll Now</button>
                 <p class="text-sm text-gray-500 mt-3">✓ Lifetime access ✓ Certificate on completion</p>`
              }
              <hr class="my-4">
              <div class="text-left text-sm">
                <p><i class="fas fa-check-circle text-green-500"></i> Full lifetime access</p>
                <p><i class="fas fa-download"></i> Downloadable resources</p>
                <p><i class="fas fa-trophy"></i> Certificate of completion</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    `;
    
    document.getElementById('root').innerHTML = wrapWithNav(html, user);
  }

  function renderCoursePlayer(course, user) {
    const enrollment = user?.enrolledCourses?.find(e => e.courseId === course.id);
    const completedLessons = enrollment?.completedLessons || [];
    
    // Mark lesson as complete
    window.markLessonComplete = function(moduleId, lessonId) {
      const users = getUsers();
      const currentUser = users.find(u => u.id === user.id);
      const enrollmentIdx = currentUser.enrolledCourses.findIndex(e => e.courseId === course.id);
      
      if (!currentUser.enrolledCourses[enrollmentIdx].completedLessons) {
        currentUser.enrolledCourses[enrollmentIdx].completedLessons = [];
      }
      
      if (!currentUser.enrolledCourses[enrollmentIdx].completedLessons.includes(lessonId)) {
        currentUser.enrolledCourses[enrollmentIdx].completedLessons.push(lessonId);
        
        // Calculate progress
        const totalLessons = course.modules.reduce((sum, m) => sum + m.lessons.length, 0);
        const progress = (currentUser.enrolledCourses[enrollmentIdx].completedLessons.length / totalLessons) * 100;
        currentUser.enrolledCourses[enrollmentIdx].progress = progress;
        
        saveUsers(users);
        setCurrentUser(currentUser);
        
        // Re-render
        const updatedUser = getCurrentUser();
        renderCoursePlayer(course, updatedUser);
      }
    };
    
    let currentLesson = enrollment?.currentLesson || course.modules[0]?.lessons[0];
    
    const html = `
      <div class="min-h-screen bg-gray-900">
        <div class="container mx-auto px-4 py-4">
          <button onclick="navigateTo('dashboard')" class="text-purple-400 mb-4 flex items-center gap-2">
            <i class="fas fa-arrow-left"></i> Back to Dashboard
          </button>
          
          <div class="grid lg:grid-cols-3 gap-6">
            <div class="lg:col-span-2">
              <div class="video-player bg-black rounded-lg overflow-hidden">
                <video controls class="w-full" src="${currentLesson?.videoUrl || 'https://www.w3schools.com/html/mov_bbb.mp4'}"></video>
              </div>
              <div class="bg-gray-800 p-4 rounded-lg mt-4">
                <h2 class="text-xl font-bold text-white">${currentLesson?.title || 'Course Content'}</h2>
                <p class="text-gray-400">${course.title}</p>
              </div>
            </div>
            
            <div class="bg-gray-800 rounded-lg p-4 h-[70vh] overflow-y-auto">
              <h3 class="text-white font-bold mb-4">Course Content</h3>
              ${course.modules.map(module => `
                <div class="mb-4">
                  <h4 class="text-purple-400 font-semibold mb-2">${module.title}</h4>
                  ${module.lessons.map(lesson => `
                    <div class="lesson-item p-3 rounded-lg mb-2 ${completedLessons.includes(lesson.id) ? 'lesson-completed bg-green-900' : 'bg-gray-700'}" 
                         onclick="selectLesson('${module.id}', '${lesson.id}')">
                      <div class="flex items-center gap-3">
                        <i class="fas ${completedLessons.includes(lesson.id) ? 'fa-check-circle text-green-400' : 'fa-play-circle text-purple-400'}"></i>
                        <span class="text-white text-sm flex-1">${lesson.title}</span>
                        <span class="text-gray-400 text-xs">${lesson.duration}</span>
                        ${!completedLessons.includes(lesson.id) ? 
                          `<button class="text-xs text-green-400" onclick="event.stopPropagation();markLessonComplete('${module.id}', '${lesson.id}')">Mark Complete</button>` :
                          '<i class="fas fa-check text-green-400 text-sm"></i>'
                        }
                      </div>
                    </div>
                  `).join('')}
                </div>
              `).join('')}
              
              <div class="mt-4 pt-4 border-t border-gray-700">
                <div class="progress-bar bg-gray-700">
                  <div class="progress-fill" style="width: ${enrollment?.progress || 0}%"></div>
                </div>
                <p class="text-gray-400 text-sm mt-2">Overall Progress: ${Math.round(enrollment?.progress || 0)}%</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    `;
    
    document.getElementById('root').innerHTML = html;
    
    window.selectLesson = function(moduleId, lessonId) {
      const lesson = course.modules.flatMap(m => m.lessons).find(l => l.id === lessonId);
      if (lesson) {
        const users = getUsers();
        const currentUser = users.find(u => u.id === user.id);
        const enrollmentIdx = currentUser.enrolledCourses.findIndex(e => e.courseId === course.id);
        currentUser.enrolledCourses[enrollmentIdx].currentLesson = lesson;
        saveUsers(users);
        setCurrentUser(currentUser);
        renderCoursePlayer(course, getCurrentUser());
      }
    };
  }

  function renderAdminPanel() {
    const courses = getCourses();
    const users = getUsers();
    const [showModal, setShowModal] = ReactState(false);
    const [editingCourse, setEditingCourse] = ReactState(null);
    
    const html = `
      <div class="flex min-h-screen">
        <div class="admin-sidebar w-64 p-6">
          <h2 class="text-xl font-bold mb-6">Admin Panel</h2>
          <div class="space-y-3">
            <button onclick="setAdminView('courses')" class="w-full text-left px-4 py-2 rounded hover:bg-purple-600">📚 Manage Courses</button>
            <button onclick="setAdminView('users')" class="w-full text-left px-4 py-2 rounded hover:bg-purple-600">👥 Manage Users</button>
            <button onclick="setAdminView('analytics')" class="w-full text-left px-4 py-2 rounded hover:bg-purple-600">📊 Analytics</button>
            <button onclick="navigateTo('home')" class="w-full text-left px-4 py-2 rounded hover:bg-purple-600 mt-10">← Back to Site</button>
          </div>
        </div>
        
        <div class="flex-1 p-8 bg-gray-100" id="adminContent">
          ${renderAdminContent(currentView, courses, users)}
        </div>
      </div>
      
      ${showModal ? `
        <div class="modal" onclick="if(event.target===this)closeModal()">
          <div class="modal-content">
            <h2 class="text-2xl font-bold mb-4">${editingCourse ? 'Edit Course' : 'Add New Course'}</h2>
            <form id="courseForm">
              <input type="text" id="courseTitle" placeholder="Course Title" value="${editingCourse?.title || ''}" required class="mb-3">
              <textarea id="courseDescription" placeholder="Description" rows="3" required class="mb-3">${editingCourse?.description || ''}</textarea>
              <input type="text" id="courseShortDesc" placeholder="Short Description" value="${editingCourse?.shortDescription || ''}" required class="mb-3">
              <input type="number" id="coursePrice" placeholder="Price (₹)" value="${editingCourse?.price || ''}" required class="mb-3">
              <input type="text" id="courseInstructor" placeholder="Instructor" value="${editingCourse?.instructor || ''}" required class="mb-3">
              <select id="courseCategory" class="mb-3">
                <option value="Development" ${editingCourse?.category === 'Development' ? 'selected' : ''}>Development</option>
                <option value="Data Science" ${editingCourse?.category === 'Data Science' ? 'selected' : ''}>Data Science</option>
                <option value="Design" ${editingCourse?.category === 'Design' ? 'selected' : ''}>Design</option>
              </select>
              <select id="courseLevel" class="mb-3">
                <option value="Beginner" ${editingCourse?.level === 'Beginner' ? 'selected' : ''}>Beginner</option>
                <option value="Intermediate" ${editingCourse?.level === 'Intermediate' ? 'selected' : ''}>Intermediate</option>
                <option value="Advanced" ${editingCourse?.level === 'Advanced' ? 'selected' : ''}>Advanced</option>
              </select>
              <input type="text" id="courseDuration" placeholder="Duration (e.g., 40 hours)" value="${editingCourse?.duration || ''}" required class="mb-3">
              <button type="submit" class="btn btn-primary w-full">${editingCourse ? 'Update Course' : 'Create Course'}</button>
            </form>
          </div>
        </div>
      ` : ''}
    `;
    
    document.getElementById('root').innerHTML = html;
    
    // Attach form handler
    setTimeout(() => {
      const form = document.getElementById('courseForm');
      if (form) {
        form.onsubmit = (e) => {
          e.preventDefault();
          const newCourse = {
            id: editingCourse?.id || Date.now().toString(),
            title: document.getElementById('courseTitle').value,
            description: document.getElementById('courseDescription').value,
            shortDescription: document.getElementById('courseShortDesc').value,
            price: parseInt(document.getElementById('coursePrice').value),
            instructor: document.getElementById('courseInstructor').value,
            category: document.getElementById('courseCategory').value,
            level: document.getElementById('courseLevel').value,
            duration: document.getElementById('courseDuration').value,
            imageUrl: 'https://via.placeholder.com/300x200/667eea/white?text=Course',
            modules: editingCourse?.modules || []
          };
          
          let coursesList = getCourses();
          if (editingCourse) {
            const index = coursesList.findIndex(c => c.id === editingCourse.id);
            coursesList[index] = newCourse;
          } else {
            coursesList.push(newCourse);
          }
          saveCourses(coursesList);
          closeModal();
          renderAdminPanel();
        };
      }
    }, 0);
  }
  
  function renderAdminContent(view, courses, users) {
    if (view === 'courses') {
      return `
        <div class="flex justify-between items-center mb-6">
          <h1 class="text-3xl font-bold">Manage Courses</h1>
          <button onclick="openAddCourseModal()" class="btn btn-primary">+ Add New Course</button>
        </div>
        <div class="grid gap-4">
          ${courses.map(course => `
            <div class="bg-white rounded-lg p-4 flex justify-between items-center">
              <div>
                <h3 class="font-bold">${course.title}</h3>
                <p class="text-sm text-gray-600">₹${course.price} • ${course.category}</p>
              </div>
              <div class="flex gap-2">
                <button onclick="editCourse('${course.id}')" class="px-4 py-2 bg-blue-500 text-white rounded">Edit</button>
                <button onclick="deleteCourse('${course.id}')" class="px-4 py-2 bg-red-500 text-white rounded">Delete</button>
              </div>
            </div>
          `).join('')}
        </div>
      `;
    } else if (view === 'users') {
      return `
        <h1 class="text-3xl font-bold mb-6">Manage Users</h1>
        <div class="grid gap-4">
          ${users.map(user => `
            <div class="bg-white rounded-lg p-4">
              <div class="flex justify-between items-center">
                <div>
                  <h3 class="font-bold">${user.name}</h3>
                  <p class="text-sm text-gray-600">${user.email}</p>
                  <p class="text-xs text-gray-500">Role: ${user.role} • Enrolled: ${user.enrolledCourses?.length || 0} courses</p>
                </div>
                <div>
                  ${user.role !== 'admin' ? `<button onclick="toggleAdminRole('${user.id}')" class="px-4 py-2 bg-purple-500 text-white rounded">Make Admin</button>` : '<span class="text-green-600">Admin</span>'}
                </div>
              </div>
            </div>
          `).join('')}
        </div>
      `;
    } else {
      const totalRevenue = courses.reduce((sum, c) => sum + (c.price * (c.totalStudents || 0)), 0);
      const totalEnrollments = users.reduce((sum, u) => sum + (u.enrolledCourses?.length || 0), 0);
      
      return `
        <h1 class="text-3xl font-bold mb-6">Analytics Dashboard</h1>
        <div class="grid md:grid-cols-3 gap-6 mb-8">
          <div class="bg-white rounded-lg p-6 text-center">
            <div class="text-3xl font-bold text-purple-600">${courses.length}</div>
            <div class="text-gray-600">Total Courses</div>
          </div>
          <div class="bg-white rounded-lg p-6 text-center">
            <div class="text-3xl font-bold text-purple-600">${users.length}</div>
            <div class="text-gray-600">Total Users</div>
          </div>
          <div class="bg-white rounded-lg p-6 text-center">
            <div class="text-3xl font-bold text-purple-600">${totalEnrollments}</div>
            <div class="text-gray-600">Enrollments</div>
          </div>
        </div>
        <div class="bg-white rounded-lg p-6">
          <h2 class="text-xl font-bold mb-4">Revenue Overview</h2>
          <div class="text-4xl font-bold text-green-600">₹${totalRevenue.toLocaleString()}</div>
          <p class="text-gray-600 mt-2">Total Revenue from all courses</p>
        </div>
      `;
    }
  }

  // Global functions for UI interaction
  window.navigateTo = (page, course = null) => {
    currentPage = page;
    if (course) selectedCourse = course;
    render();
  };
  
  window.selectCourse = (courseId) => {
    const courses = getCourses();
    selectedCourse = courses.find(c => c.id === courseId);
    currentPage = 'course-details';
    render();
  };
  
  window.continueLearning = (courseId) => {
    const courses = getCourses();
    selectedCourse = courses.find(c => c.id === courseId);
    currentPage = 'course-player';
    render();
  };
  
  window.enrollInCourse = async (courseId) => {
    const courses = getCourses();
    const course = courses.find(c => c.id === courseId);
    const user = getCurrentUser();
    
    if (!user) {
      alert('Please login first');
      return;
    }
    
    const paymentResult = await simulatePayment(course.price, course.title);
    
    if (paymentResult.success) {
      // Enroll user
      const users = getUsers();
      const userIndex = users.findIndex(u => u.id === user.id);
      
      if (!users[userIndex].enrolledCourses) {
        users[userIndex].enrolledCourses = [];
      }
      
      users[userIndex].enrolledCourses.push({
        courseId: course.id,
        enrolledAt: new Date().toISOString(),
        progress: 0,
        completedLessons: [],
        paymentId: paymentResult.paymentId
      });
      
      // Increment course students
      const courseIndex = courses.findIndex(c => c.id === courseId);
      courses[courseIndex].totalStudents = (courses[courseIndex].totalStudents || 0) + 1;
      
      saveUsers(users);
      saveCourses(courses);
      setCurrentUser(users[userIndex]);
      
      // Send email notification
      sendEmailNotification(user.email, 'Course Enrollment Confirmation', 
        `You have successfully enrolled in ${course.title}. Start learning now!`);
      
      alert(`✅ Successfully enrolled in ${course.title}!`);
      navigateTo('dashboard');
    } else {
      alert('Payment cancelled');
    }
  };
  
  window.handleLogin = () => {
    const email = document.getElementById('loginEmail').value;
    const password = document.getElementById('loginPassword').value;
    const users = getUsers();
    const user = users.find(u => u.email === email && u.password === password);
    
    if (user) {
      setCurrentUser(user);
      render();
    } else {
      alert('Invalid credentials');
    }
  };
  
  window.handleRegister = () => {
    const name = document.getElementById('regName').value;
    const email = document.getElementById('regEmail').value;
    const password = document.getElementById('regPassword').value;
    const users = getUsers();
    
    if (users.find(u => u.email === email)) {
      alert('User already exists');
      return;
    }
    
    const newUser = {
      id: Date.now().toString(),
      name,
      email,
      password,
      role: 'user',
      isVerified: true,
      enrolledCourses: []
    };
    
    users.push(newUser);
    saveUsers(users);
    setCurrentUser(newUser);
    
    sendEmailNotification(email, 'Welcome to StudyGenie Pro!', 
      `Hi ${name}, welcome to our platform! Start exploring courses today.`);
    
    alert('Registration successful!');
    render();
  };
  
  window.handleLogout = () => {
    setCurrentUser(null);
    render();
  };
  
  window.showLogin = () => {
    document.getElementById('loginForm').style.display = 'block';
    document.getElementById('registerForm').style.display = 'none';
    document.getElementById('forgotForm').style.display = 'none';
    document.getElementById('loginTab').classList.add('bg-purple-600', 'text-white');
    document.getElementById('loginTab').classList.remove('bg-gray-200');
    document.getElementById('registerTab').classList.remove('bg-purple-600', 'text-white');
    document.getElementById('registerTab').classList.add('bg-gray-200');
  };
  
  window.showRegister = () => {
    document.getElementById('loginForm').style.display = 'none';
    document.getElementById('registerForm').style.display = 'block';
    document.getElementById('forgotForm').style.display = 'none';
    document.getElementById('registerTab').classList.add('bg-purple-600', 'text-white');
    document.getElementById('registerTab').classList.remove('bg-gray-200');
    document.getElementById('loginTab').classList.remove('bg-purple-600', 'text-white');
    document.getElementById('loginTab').classList.add('bg-gray-200');
  };
  
  window.showForgotPassword = () => {
    document.getElementById('loginForm').style.display = 'none';
    document.getElementById('registerForm').style.display = 'none';
    document.getElementById('forgotForm').style.display = 'block';
  };
  
  window.handleForgotPassword = () => {
    const email = document.getElementById('forgotEmail').value;
    sendEmailNotification(email, 'Password Reset Request', 'Click here to reset your password: [demo-reset-link]');
    alert('Password reset link sent to your email!');
    showLogin();
  };
  
  // Admin functions
  window.setAdminView = (view) => {
    currentView = view;
    renderAdminPanel();
  };
  
  window.openAddCourseModal = () => {
    window.editCourse(null);
  };
  
  window.editCourse = (courseId) => {
    const courses = getCourses();
    const course = courseId ? courses.find(c => c.id === courseId) : null;
    window.editingCourse = course;
    window.showModal = true;
    renderAdminPanel();
  };
  
  window.closeModal = () => {
    window.showModal = false;
    renderAdminPanel();
  };
  
  window.deleteCourse = (courseId) => {
    if (confirm('Are you sure you want to delete this course?')) {
      const courses = getCourses().filter(c => c.id !== courseId);
      saveCourses(courses);
      renderAdminPanel();
    }
  };
  
  window.toggleAdminRole = (userId) => {
    const users = getUsers();
    const userIndex = users.findIndex(u => u.id === userId);
    users[userIndex].role = 'admin';
    saveUsers(users);
    renderAdminPanel();
  };
  
  // Helper for React-like state
  function ReactState(initial) {
    let value = initial;
    return [value, (newVal) => { value = newVal; }];
  }
  
  function wrapWithNav(content, user) {
    return `
      <div class="min-h-screen">
        <nav class="bg-white shadow-md sticky top-0 z-50">
          <div class="container mx-auto px-4 py-4 flex justify-between items-center">
            <div class="flex items-center gap-2 cursor-pointer" onclick="navigateTo('home')">
              <i class="fas fa-brain text-2xl text-purple-600"></i>
              <span class="text-xl font-bold">StudyGenie Pro</span>
            </div>
            <div class="flex gap-4 items-center">
              <span class="text-gray-700">Welcome, ${user?.name}</span>
              <button onclick="navigateTo('dashboard')" class="text-gray-600 hover:text-purple-600">My Dashboard</button>
              ${user?.role === 'admin' ? '<button onclick="navigateTo(\'admin\')" class="text-gray-600 hover:text-purple-600">Admin Panel</button>' : ''}
              <button onclick="handleLogout()" class="text-red-600 hover:text-red-700">Logout</button>
            </div>
          </div>
        </nav>
        ${content}
      </div>
    `;
  }
  
  // Initialize and render
  initializeData();
  render();
</script>

