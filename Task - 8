  // Storage keys
  const STORAGE_KEYS = {
    USERS: 'course_platform_users',
    COURSES: 'course_platform_courses',
    CURRENT_USER: 'course_platform_current_user',
    TOKEN: 'course_platform_token'
  };

  // Initialize localStorage
  function initializeData() {
    if (!localStorage.getItem(STORAGE_KEYS.USERS)) {
      localStorage.setItem(STORAGE_KEYS.USERS, JSON.stringify(initialUsers));
    }
    if (!localStorage.getItem(STORAGE_KEYS.COURSES)) {
      localStorage.setItem(STORAGE_KEYS.COURSES, JSON.stringify(initialCourses));
    }
  }

  // Helper functions
  function getUsers() {
    return JSON.parse(localStorage.getItem(STORAGE_KEYS.USERS));
  }

  function getCourses() {
    return JSON.parse(localStorage.getItem(STORAGE_KEYS.COURSES));
  }

  function saveCourses(courses) {
    localStorage.setItem(STORAGE_KEYS.COURSES, JSON.stringify(courses));
  }

  function saveUsers(users) {
    localStorage.setItem(STORAGE_KEYS.USERS, JSON.stringify(users));
  }

  function getCurrentUser() {
    const token = localStorage.getItem(STORAGE_KEYS.TOKEN);
    if (!token) return null;
    const users = getUsers();
    return users.find(u => u.id === token) || null;
  }

  function setCurrentUser(user) {
    if (user) {
      localStorage.setItem(STORAGE_KEYS.TOKEN, user.id);
      localStorage.setItem(STORAGE_KEYS.CURRENT_USER, JSON.stringify(user));
    } else {
      localStorage.removeItem(STORAGE_KEYS.TOKEN);
      localStorage.removeItem(STORAGE_KEYS.CURRENT_USER);
    }
  }

  // Simulate email notification
  function sendEmailNotification(to, subject, message) {
    console.log(`📧 Email sent to ${to}: ${subject} - ${message}`);
    // In real app, this would call an API
    alert(`📧 Demo: Email sent to ${to}\nSubject: ${subject}\nMessage: ${message}`);
  }

  // Simulate payment
  function simulatePayment(amount, courseTitle) {
    return new Promise((resolve) => {
      // Simulate Razorpay-like payment modal
      const confirmed = confirm(`💳 Payment Simulation\nCourse: ${courseTitle}\nAmount: ₹${amount}\n\nClick OK to complete payment (Test Mode)`);
      if (confirmed) {
        setTimeout(() => {
          resolve({ success: true, paymentId: 'pay_' + Date.now() });
        }, 1000);
      } else {
        resolve({ success: false });
      }
    });
  }

  // React-like app using pure JS
  let currentPage = 'home';
  let selectedCourse = null;
  let currentView = 'courses'; // for admin

  function render() {
    const user = getCurrentUser();
    const isAdmin = user?.role === 'admin';
    
    if (!user) {
      renderAuthPage();
    } else if (isAdmin && currentPage === 'admin') {
      renderAdminPanel();
    } else if (currentPage === 'home') {
      renderHomePage(user);
    } else if (currentPage === 'dashboard') {
      renderDashboard(user);
    } else if (currentPage === 'course-details' && selectedCourse) {
      renderCourseDetails(selectedCourse, user);
    } else if (currentPage === 'course-player' && selectedCourse) {
      renderCoursePlayer(selectedCourse, user);
    } else {
      renderHomePage(user);
    }
  }

  function renderAuthPage() {
    const html = `
