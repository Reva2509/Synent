        <nav class="bg-white shadow-md sticky top-0 z-50">
          <div class="container mx-auto px-4 py-4 flex justify-between items-center">
            <div class="flex items-center gap-2 cursor-pointer" onclick="navigateTo('home')">
              <i class="fas fa-brain text-2xl text-purple-600"></i>
              <span class="text-xl font-bold">StudyGenie Pro</span>
            </div>
            <div class="flex gap-4 items-center">
              <span class="text-gray-700">Welcome, ${user?.name}</span>
              <button onclick="navigateTo('dashboard')" class="text-gray-600 hover:text-purple-600">My Dashboard</button>
              ${user?.role === 'admin' ? '<button onclick="navigateTo(\'admin\')" class="text-gray-600 hover:text-purple-600">Admin Panel</button>' : ''}
              <button onclick="handleLogout()" class="text-red-600 hover:text-red-700">Logout</button>
            </div>
          </div>
        </nav>
        ${html}
      </div>
    `;
  }

  function renderDashboard(user) {
    const courses = getCourses();
    const enrolled = user.enrolledCourses || [];
    const enrolledCoursesData = enrolled.map(en => ({
      ...courses.find(c => c.id === en.courseId),
      progress: en.progress || 0
    })).filter(c => c);

    const availableCourses = courses.filter(c => !enrolled.some(e => e.courseId === c.id));

    const html = `
      <div class="container mx-auto px-4 py-8">
        <h1 class="text-3xl font-bold mb-8">My Learning Dashboard</h1>
        
        <div class="grid lg:grid-cols-3 gap-6">
          <div class="lg:col-span-2">
            <h2 class="text-2xl font-semibold mb-4">My Courses</h2>
            ${enrolledCoursesData.length === 0 ? 
              '<div class="glass-card p-8 text-center"><p class="text-gray-600">You haven\'t enrolled in any courses yet.</p><button onclick="navigateTo(\'home\')" class="btn btn-primary mt-4">Browse Courses</button></div>' :
              enrolledCoursesData.map(course => `
                <div class="glass-card p-6 mb-4">
                  <div class="flex justify-between items-start mb-3">
                    <div>
                      <h3 class="text-xl font-bold">${course.title}</h3>
