  }

  function renderHomePage(user) {
    const courses = getCourses();
    const categories = [...new Set(courses.map(c => c.category))];
    
    const html = `
      <div class="bg-gradient-to-r from-purple-600 to-blue-500 text-white py-20">
        <div class="container mx-auto px-4 text-center">
          <h1 class="text-5xl font-bold mb-4">Transform Your Career with Expert Courses</h1>
          <p class="text-xl mb-8">Learn from industry experts • Flexible learning • Lifetime access</p>
          <button onclick="navigateTo('dashboard')" class="btn bg-white text-purple-600 hover:shadow-lg">Browse Courses →</button>
        </div>
      </div>
      
      <div class="container mx-auto px-4 py-12">
        <h2 class="text-3xl font-bold mb-8">Featured Courses</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="courseGrid">
