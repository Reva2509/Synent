              <a href="#" onclick="showForgotPassword()" class="text-purple-600">Forgot Password?</a>
            </p>
            <p class="text-center mt-2 text-xs text-gray-500">Demo: admin@studyGenie.com / admin123</p>
          </div>
          
          <div id="registerForm" style="display:none;" class="auth-form">
            <input type="text" id="regName" placeholder="Full Name" class="w-full mb-3" />
            <input type="email" id="regEmail" placeholder="Email" class="w-full mb-3" />
            <input type="password" id="regPassword" placeholder="Password" class="w-full mb-4" />
            <button onclick="handleRegister()" class="btn btn-primary w-full">Create Account</button>
          </div>
          
          <div id="forgotForm" style="display:none;" class="auth-form">
            <input type="email" id="forgotEmail" placeholder="Email" class="w-full mb-4" />
            <button onclick="handleForgotPassword()" class="btn btn-primary w-full">Send Reset Link</button>
            <button onclick="showLogin()" class="btn btn-outline w-full mt-2">Back to Login</button>
