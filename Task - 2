<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>StudyGenie | AI-Powered Study Assistant</title>
  <!-- Google Fonts + modern font stack -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
  <!-- Font Awesome 6 (free icons) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    /* ---------- RESET & GLOBAL ---------- */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #fbfcff;
      color: #0a1a2f;
      line-height: 1.5;
      scroll-behavior: smooth;
    }

    /* modern gradient background containers */
    .gradient-bg {
      background: radial-gradient(circle at 10% 20%, rgba(106, 13, 173, 0.05), rgba(0, 212, 255, 0.02));
    }

    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 32px;
    }

    /* buttons & links */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-weight: 600;
      border-radius: 48px;
      padding: 12px 28px;
      transition: all 0.3s cubic-bezier(0.2, 0.9, 0.4, 1.1);
      text-decoration: none;
      font-size: 1rem;
      cursor: pointer;
      border: none;
      letter-spacing: -0.01em;
    }

    .btn-primary {
      background: linear-gradient(135deg, #6C2BD9, #3A0CA3);
      color: white;
      box-shadow: 0 8px 20px rgba(108, 43, 217, 0.25);
    }

    .btn-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 18px 30px rgba(108, 43, 217, 0.35);
      background: linear-gradient(135deg, #7e3af2, #4b12c2);
    }

    .btn-outline {
      background: transparent;
      border: 1.5px solid #cbd5e1;
      color: #1e293b;
    }

    .btn-outline:hover {
      border-color: #6C2BD9;
      background: rgba(108, 43, 217, 0.05);
      transform: translateY(-2px);
    }

    /* headings */
    h1, h2, h3 {
      font-weight: 800;
      line-height: 1.2;
      letter-spacing: -0.02em;
    }

    h2 {
      font-size: 2.2rem;
      margin-bottom: 1rem;
    }

    .section-title {
      text-align: center;
      font-size: 2.3rem;
      margin-bottom: 3rem;
    }

    /* ----- HERO SECTION (full-screen modern) ----- */
    .hero {
      min-height: 90vh;
      display: flex;
      align-items: center;
      padding: 5rem 0 4rem;
      position: relative;
    }

    .hero-grid {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 3rem;
    }

    .hero-content {
      flex: 1 1 45%;
    }

    .hero-badge {
      background: rgba(108, 43, 217, 0.12);
      color: #4c1d95;
      display: inline-block;
      padding: 6px 16px;
      border-radius: 40px;
      font-size: 0.85rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
    }

    .hero-content h1 {
      font-size: 3.5rem;
      margin-bottom: 1.2rem;
      background: linear-gradient(135deg, #0f172a, #4c1d95);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
    }

    .hero-sub {
      font-size: 1.2rem;
      color: #334155;
      margin-bottom: 2rem;
      max-width: 90%;
    }

    .btn-group {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .hero-illustration {
      flex: 1 1 45%;
      background: linear-gradient(145deg, #f0f4ff, #e9edfc);
      border-radius: 48px;
      padding: 1rem;
      text-align: center;
      box-shadow: 0 25px 40px -12px rgba(0, 0, 0, 0.1);
      transition: transform 0.3s ease;
    }

    .hero-illustration:hover {
      transform: scale(1.01);
    }

    .hero-illustration svg {
      max-width: 100%;
      height: auto;
    }

    /* Features section */
    .features {
      padding: 5rem 0;
      background: #ffffff;
    }

    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 2rem;
    }

    .feature-card {
      background: #ffffff;
      border-radius: 32px;
      padding: 1.8rem;
      transition: all 0.35s ease;
      box-shadow: 0 12px 28px -8px rgba(0, 0, 0, 0.06);
      border: 1px solid rgba(203, 213, 225, 0.4);
      text-align: center;
      backdrop-filter: blur(0px);
    }

    .feature-card:hover {
      transform: translateY(-10px);
      border-color: #c4b5fd;
      box-shadow: 0 28px 40px -16px rgba(108, 43, 217, 0.2);
      background: #fefeff;
    }

    .feature-icon {
      font-size: 3rem;
      margin-bottom: 1.2rem;
      display: inline-block;
      background: linear-gradient(145deg, #f0eafc, #fff);
      width: 70px;
      height: 70px;
      line-height: 70px;
      border-radius: 30px;
      box-shadow: 0 8px 12px -6px rgba(0,0,0,0.05);
    }

    .feature-card h3 {
      font-size: 1.5rem;
      margin-bottom: 0.75rem;
    }

    .feature-card p {
      color: #475569;
      font-size: 0.95rem;
    }

    /* Testimonials (bonus) */
    .testimonials {
      padding: 5rem 0;
      background: linear-gradient(112deg, #f8faff 0%, #f3f0fc 100%);
    }

    .testimonial-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 2rem;
      justify-content: center;
    }

    .testimonial-card {
      background: white;
      border-radius: 28px;
      padding: 2rem 1.8rem;
      flex: 1 1 280px;
      box-shadow: 0 20px 35px -12px rgba(0,0,0,0.08);
      transition: all 0.3s;
      border: 1px solid #e9eef5;
    }

    .testimonial-card:hover {
      transform: scale(1.02);
      border-color: #b9a9f0;
    }

    .stars {
      color: #fbbf24;
      margin-bottom: 1rem;
      letter-spacing: 2px;
    }

    .testimonial-text {
      font-size: 1rem;
      color: #1e293b;
      margin: 1rem 0;
      font-style: normal;
      font-weight: 500;
    }

    .student-name {
      font-weight: 700;
      margin-top: 0.8rem;
      color: #3A0CA3;
    }

    /* CTA Section */
    .cta-section {
      padding: 5rem 1rem;
      text-align: center;
      background: radial-gradient(ellipse at 70% 30%, #0f172a, #030617);
      color: white;
      border-radius: 0;
      margin: 0;
    }

    .cta-section h2 {
      font-size: 2.5rem;
      color: white;
    }

    .cta-section .btn-primary {
      background: white;
      color: #3A0CA3;
      box-shadow: 0 8px 18px rgba(0,0,0,0.2);
      margin-top: 1.8rem;
    }

    .cta-section .btn-primary:hover {
      background: #f4f1ff;
      transform: scale(1.03);
      color: #250b6b;
    }

    /* Footer */
    .footer {
      background: #0a0e1c;
      color: #cbd5e6;
      padding: 3rem 0 1.5rem;
    }

    .footer-content {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 2rem;
      margin-bottom: 2rem;
    }

    .footer-brand h3 {
      font-size: 1.8rem;
      color: white;
      margin-bottom: 0.5rem;
    }

    .footer-brand p {
      max-width: 260px;
      font-size: 0.9rem;
    }

    .footer-links {
      display: flex;
      gap: 3rem;
      flex-wrap: wrap;
    }

    .link-col h4 {
      color: white;
      margin-bottom: 1rem;
    }

    .link-col ul {
      list-style: none;
    }

    .link-col li {
      margin-bottom: 0.7rem;
    }

    .link-col a {
      color: #9ca3af;
      text-decoration: none;
      transition: color 0.2s;
    }

    .link-col a:hover {
      color: #b9a9f0;
    }

    .social-icons a {
      color: #cbd5e6;
      font-size: 1.3rem;
      margin-right: 1.2rem;
      transition: 0.2s;
      display: inline-block;
    }

    .social-icons a:hover {
      color: white;
      transform: translateY(-3px);
    }

    .copyright {
      text-align: center;
      padding-top: 2rem;
      border-top: 1px solid #1e293b;
      font-size: 0.8rem;
    }

    /* Responsive design */
    @media (max-width: 992px) {
      .hero-content h1 {
        font-size: 2.6rem;
      }
      .container {
        padding: 0 24px;
      }
      .hero-grid {
        flex-direction: column;
        text-align: center;
      }
      .hero-sub {
        max-width: 100%;
      }
      .btn-group {
        justify-content: center;
      }
      .hero-illustration {
        width: 100%;
      }
      .section-title {
        font-size: 1.9rem;
      }
    }

    @media (max-width: 640px) {
      .hero {
        min-height: auto;
        padding: 2rem 0 3rem;
      }
      .hero-content h1 {
        font-size: 2rem;
      }
      .hero-sub {
        font-size: 1rem;
      }
      .btn {
        padding: 10px 20px;
        font-size: 0.9rem;
      }
      .cards-grid {
        gap: 1.2rem;
      }
      .feature-card {
        padding: 1.5rem;
      }
      .footer-content {
        flex-direction: column;
        text-align: center;
      }
      .footer-links {
        justify-content: center;
      }
      .social-icons {
        text-align: center;
        margin-top: 1rem;
      }
      .cta-section h2 {
        font-size: 1.9rem;
      }
    }

    /* small extra details */
    .fa-regular, .fas, .far {
      font-size: inherit;
    }
    .highlight {
      font-weight: 600;
    }
  </style>
</head>
