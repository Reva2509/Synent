<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>GitHub Explorer | API Integration Project</title>
  <!-- Google Fonts + modern font -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
  <!-- Font Awesome 6 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
      min-height: 100vh;
      padding: 2rem 1.5rem;
    }

    /* main container */
    .api-container {
      max-width: 1100px;
      margin: 0 auto;
    }

    /* header */
    .api-header {
      text-align: center;
      margin-bottom: 2.5rem;
    }

    .api-header h1 {
      font-size: 2.8rem;
      font-weight: 800;
      background: linear-gradient(135deg, #a78bfa, #60a5fa);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      margin-bottom: 0.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
    }

    .api-header p {
      color: #cbd5e1;
      font-size: 1rem;
    }

    /* search card */
    .search-card {
      background: rgba(30, 41, 59, 0.7);
      backdrop-filter: blur(12px);
      border-radius: 32px;
      padding: 1.5rem;
      margin-bottom: 2rem;
      border: 1px solid rgba(255,255,255,0.1);
      box-shadow: 0 20px 35px -12px rgba(0,0,0,0.3);
    }

    .input-group {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .search-input {
      flex: 1;
      padding: 1rem 1.2rem;
      border: 2px solid #334155;
      border-radius: 48px;
      font-size: 1rem;
      font-family: 'Inter', sans-serif;
      background: #0f172a;
      color: white;
      transition: all 0.2s;
      outline: none;
    }

    .search-input:focus {
      border-color: #8b5cf6;
      box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.3);
    }

    .search-input::placeholder {
      color: #64748b;
    }

    .search-btn {
      background: linear-gradient(135deg, #8b5cf6, #6d28d9);
      border: none;
      padding: 0 2rem;
      border-radius: 48px;
      color: white;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: 'Inter', sans-serif;
    }

    .search-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px -5px rgba(139, 92, 246, 0.5);
    }

    .search-btn:active {
      transform: translateY(0);
    }

    /* examples row */
    .examples {
      margin-top: 1rem;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: center;
    }

    .example-badge {
      background: rgba(139, 92, 246, 0.2);
      padding: 6px 14px;
      border-radius: 40px;
      font-size: 0.75rem;
      color: #c4b5fd;
      cursor: pointer;
      transition: all 0.2s;
    }

    .example-badge:hover {
      background: #8b5cf6;
      color: white;
      transform: scale(1.02);
    }

    /* loading state */
    .loading-state {
      text-align: center;
      padding: 3rem;
      background: rgba(30, 41, 59, 0.5);
      border-radius: 32px;
      margin-top: 1rem;
    }

    .spinner {
      width: 50px;
      height: 50px;
      border: 4px solid rgba(139, 92, 246, 0.2);
      border-top: 4px solid #8b5cf6;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto 1rem;
    }

    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    /* error state */
    .error-state {
      background: rgba(239, 68, 68, 0.15);
      border: 1px solid rgba(239, 68, 68, 0.4);
      border-radius: 24px;
      padding: 2rem;
      text-align: center;
      color: #fca5a5;
    }

    /* user profile card */
    .profile-card {
      background: linear-gradient(135deg, #1e293b, #0f172a);
      border-radius: 32px;
      padding: 2rem;
      margin-bottom: 2rem;
      border: 1px solid rgba(139, 92, 246, 0.3);
      box-shadow: 0 25px 40px -12px rgba(0,0,0,0.4);
      transition: transform 0.2s;
    }

    .profile-header {
      display: flex;
      flex-wrap: wrap;
      gap: 2rem;
      align-items: center;
      margin-bottom: 2rem;
    }

    .avatar {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      border: 4px solid #8b5cf6;
      object-fit: cover;
    }

    .profile-info h2 {
      font-size: 2rem;
      color: white;
      margin-bottom: 0.5rem;
    }

    .profile-info .username {
      color: #a78bfa;
      font-size: 1rem;
      margin-bottom: 0.5rem;
    }

    .bio {
      color: #cbd5e1;
      max-width: 500px;
      margin-top: 0.5rem;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 1rem;
      margin: 1.5rem 0;
    }

    .stat-card {
      background: rgba(255,255,255,0.05);
      padding: 1rem;
      border-radius: 20px;
      text-align: center;
      transition: all 0.2s;
    }

    .stat-card:hover {
      background: rgba(139, 92, 246, 0.2);
      transform: translateY(-3px);
    }

    .stat-number {
      font-size: 1.8rem;
      font-weight: 800;
      color: #c4b5fd;
    }

    .stat-label {
      font-size: 0.8rem;
      color: #94a3b8;
      margin-top: 0.3rem;
    }

    /* repos section */
    .repos-section {
      margin-top: 2rem;
    }

    .section-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: white;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .repo-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1rem;
    }

    .repo-card {
      background: rgba(30, 41, 59, 0.6);
      backdrop-filter: blur(8px);
      border-radius: 20px;
      padding: 1.2rem;
      border: 1px solid rgba(255,255,255,0.08);
      transition: all 0.25s;
    }

    .repo-card:hover {
      transform: translateY(-4px);
      border-color: #8b5cf6;
      background: rgba(139, 92, 246, 0.1);
    }

    .repo-name {
      font-size: 1.1rem;
      font-weight: 700;
      color: #a78bfa;
      margin-bottom: 0.5rem;
      word-break: break-all;
    }

    .repo-desc {
      font-size: 0.85rem;
      color: #94a3b8;
      margin-bottom: 0.8rem;
      line-height: 1.4;
    }

    .repo-meta {
      display: flex;
      gap: 1rem;
      font-size: 0.75rem;
      color: #64748b;
    }

    .repo-meta i {
      margin-right: 4px;
    }

    /* footer */
    .footer-note {
      text-align: center;
      margin-top: 2rem;
      color: #64748b;
      font-size: 0.8rem;
    }

    /* responsive */
    @media (max-width: 640px) {
      body {
        padding: 1rem;
      }
      .api-header h1 {
        font-size: 1.8rem;
      }
      .profile-header {
        flex-direction: column;
        text-align: center;
      }
      .avatar {
        width: 90px;
        height: 90px;
      }
      .profile-info h2 {
        font-size: 1.5rem;
      }
      .search-btn {
        padding: 0 1.2rem;
        font-size: 0.9rem;
      }
    }
  </style>
</head>
<body>

<div class="api-container">
  <div class="api-header">
    <h1><i class="fab fa-github"></i> GitHub Explorer</h1>
    <p>Discover GitHub profiles — fetch users, repositories, and stats using the GitHub API</p>
  </div>

  <div class="search-card">
    <div class="input-group">
      <input type="text" id="usernameInput" class="search-input" placeholder="Enter GitHub username... e.g., 'octocat', 'torvalds', 'gaearon'" autocomplete="off">
      <button id="searchBtn" class="search-btn"><i class="fas fa-search"></i> Explore</button>
    </div>
    <div class="examples">
      <span class="example-badge" data-username="octocat">🐙 octocat</span>
      <span class="example-badge" data-username="torvalds">🐧 torvalds</span>
      <span class="example-badge" data-username="gaearon">⚛️ gaearon</span>
      <span class="example-badge" data-username="vercel">▲ vercel</span>
      <span class="example-badge" data-username="microsoft">💼 microsoft</span>
    </div>
  </div>

  <!-- Dynamic content area -->
  <div id="contentArea">
    <!-- initial welcome message -->
    <div class="profile-card" style="text-align: center; background: rgba(30,41,59,0.4);">
      <i class="fab fa-github-alt" style="font-size: 4rem; color: #8b5cf6; margin-bottom: 1rem;"></i>
      <h3 style="color: white;">GitHub API Integration</h3>
      <p style="color: #94a3b8; margin-top: 0.5rem;">Search for any GitHub user to see their profile, repositories, and detailed statistics. <br> Built with Fetch API, loading states, and error handling.</p>
    </div>
  </div>
  <div class="footer-note">
    <i class="fas fa-database"></i> Powered by GitHub REST API • Real-time data • Rate limits apply
  </div>
</div>

<script>
  // DOM elements
  const usernameInput = document.getElementById('usernameInput');
  const searchBtn = document.getElementById('searchBtn');
  const contentArea = document.getElementById('contentArea');

  // Loading indicator + error + display logic
  function showLoading() {
    contentArea.innerHTML = `
      <div class="loading-state">
        <div class="spinner"></div>
        <p style="color: #cbd5e1;">Fetching GitHub data...</p>
        <p style="font-size: 0.8rem; color:#64748b;">Requesting user profile & repositories</p>
      </div>
    `;
  }

  function showError(message) {
    contentArea.innerHTML = `
      <div class="error-state">
        <i class="fas fa-exclamation-triangle" style="font-size: 2.5rem; margin-bottom: 1rem;"></i>
        <h3 style="margin-bottom: 0.5rem;">Oops! Something went wrong</h3>
        <p>${message}</p>
        <button id="retryBtn" style="margin-top: 1rem; background: #8b5cf6; border: none; padding: 8px 20px; border-radius: 40px; color: white; cursor: pointer; font-weight: 600;">Try Again</button>
      </div>
    `;
    const retryBtn = document.getElementById('retryBtn');
    if (retryBtn) {
      retryBtn.addEventListener('click', () => {
        const username = usernameInput.value.trim();
        if (username) fetchGitHubUser(username);
        else fetchGitHubUser('octocat');
      });
    }
  }

  // main fetch function: user data + repos
  async function fetchGitHubUser(username) {
    if (!username || username.trim() === '') {
      showError('Please enter a valid GitHub username.');
      return;
    }
    
    showLoading();
    
    try {
      // Fetch user profile
      const userResponse = await fetch(`https://api.github.com/users/${encodeURIComponent(username)}`);
      
      if (!userResponse.ok) {
        if (userResponse.status === 404) {
          throw new Error(`User "${username}" not found. Check the spelling or try another username.`);
        } else if (userResponse.status === 403) {
          throw new Error(`API rate limit exceeded. Please try again later.`);
        } else {
          throw new Error(`GitHub API error (${userResponse.status}). Please try again.`);
        }
      }
      
      const userData = await userResponse.json();
      
      // Fetch repositories (sort by stars, limit 6 for better presentation)
      const reposResponse = await fetch(`https://api.github.com/users/${encodeURIComponent(username)}/repos?sort=updated&per_page=12&direction=desc`);
      
      if (!reposResponse.ok) {
        // Non-critical error: show profile but repos failed
        console.warn('Repos fetch failed');
        renderUserProfile(userData, []);
        return;
      }
      
      const reposData = await reposResponse.json();
      renderUserProfile(userData, reposData);
      
    } catch (error) {
      console.error('Fetch error:', error);
      showError(error.message || 'Network error. Please check your connection and try again.');
    }
  }
  
  // Render the complete UI with user profile and repos
  function renderUserProfile(user, repos) {
    // format dates
    const joinDate = new Date(user.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    
    // bio fallback
    const bio = user.bio || 'No bio provided.';
    
    // website / blog
    const blogUrl = user.blog && user.blog !== '' ? user.blog : null;
    
    // company fallback
    const company = user.company || 'Not specified';
    const location = user.location || 'Unknown';
    
    // repo stats 
    const totalStars = repos.reduce((sum, repo) => sum + (repo.stargazers_count || 0), 0);
    const topLanguage = getMostUsedLanguage(repos);
    
    // build repos HTML
    let reposHtml = '';
    if (repos && repos.length > 0) {
      reposHtml = `
        <div class="repos-section">
          <div class="section-title">
            <i class="fas fa-code-branch"></i> Recent Repositories (${repos.length} shown)
          </div>
          <div class="repo-grid">
            ${repos.map(repo => `
              <div class="repo-card">
                <div class="repo-name">
                  <i class="fas fa-book"></i> 
                  <a href="${repo.html_url}" target="_blank" style="color: #a78bfa; text-decoration: none;">${repo.name}</a>
                </div>
                <div class="repo-desc">${repo.description ? truncate(repo.description, 100) : 'No description provided.'}</div>
                <div class="repo-meta">
                  <span><i class="fas fa-star"></i> ${repo.stargazers_count}</span>
                  <span><i class="fas fa-code-branch"></i> ${repo.forks_count}</span>
                  <span><i class="fas fa-circle" style="color: #8b5cf6; font-size: 0.7rem;"></i> ${repo.language || 'N/A'}</span>
                </div>
              </div>
            `).join('')}
          </div>
        </div>
      `;
    } else {
      reposHtml = `<div class="repos-section"><div class="error-state" style="background: transparent;"><p><i class="fas fa-inbox"></i> No public repositories found for this user.</p></div></div>`;
    }
    
    const profileHtml = `
      <div class="profile-card">
        <div class="profile-header">
          <img src="${user.avatar_url}" alt="${user.login}" class="avatar" onerror="this.src='https://github.githubassets.com/images/modules/logos_page/GitHub-Mark.png'">
          <div class="profile-info">
            <h2>${user.name || user.login}</h2>
            <div class="username">
              <i class="fab fa-github"></i> @${user.login}
            </div>
            <div class="bio">${escapeHtml(bio)}</div>
            <div style="display: flex; flex-wrap: wrap; gap: 12px; margin-top: 12px; font-size: 0.8rem; color: #94a3b8;">
              ${location !== 'Unknown' ? `<span><i class="fas fa-map-marker-alt"></i> ${escapeHtml(location)}</span>` : ''}
              ${company !== 'Not specified' ? `<span><i class="fas fa-building"></i> ${escapeHtml(company)}</span>` : ''}
              ${blogUrl ? `<span><i class="fas fa-link"></i> <a href="${blogUrl}" target="_blank" style="color:#a78bfa;">Website</a></span>` : ''}
              <span><i class="fas fa-calendar-alt"></i> Joined ${joinDate}</span>
            </div>
          </div>
        </div>
        
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-number">${user.public_repos}</div>
            <div class="stat-label">Repositories</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">${user.followers}</div>
            <div class="stat-label">Followers</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">${user.following}</div>
            <div class="stat-label">Following</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">${totalStars}</div>
            <div class="stat-label">⭐ Total Stars</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">${topLanguage || '—'}</div>
            <div class="stat-label">Top Language</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">${user.public_gists || 0}</div>
            <div class="stat-label">Gists</div>
          </div>
        </div>
        
        ${reposHtml}
      </div>
    `;
    
    contentArea.innerHTML = profileHtml;
  }
  
  // Helper: get most used language from repos
  function getMostUsedLanguage(repos) {
    if (!repos || repos.length === 0) return null;
    const langCount = {};
    repos.forEach(repo => {
      if (repo.language) {
        langCount[repo.language] = (langCount[repo.language] || 0) + 1;
      }
    });
    let maxLang = null;
    let maxCount = 0;
    for (const [lang, count] of Object.entries(langCount)) {
      if (count > maxCount) {
        maxCount = count;
        maxLang = lang;
      }
    }
    return maxLang;
  }
  
  function truncate(str, maxLen) {
    if (!str) return '';
    return str.length > maxLen ? str.substring(0, maxLen) + '...' : str;
  }
  
  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    });
  }
  
  // event listeners
  function initEventListeners() {
    searchBtn.addEventListener('click', () => {
      const username = usernameInput.value.trim();
      if (username) fetchGitHubUser(username);
      else fetchGitHubUser('octocat');
    });
    
    usernameInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        const username = usernameInput.value.trim();
        if (username) fetchGitHubUser(username);
        else fetchGitHubUser('octocat');
      }
    });
    
    // example badges
    document.querySelectorAll('.example-badge').forEach(badge => {
      badge.addEventListener('click', () => {
        const username = badge.getAttribute('data-username');
        if (username) {
          usernameInput.value = username;
          fetchGitHubUser(username);
        }
      });
    });
  }
  
  // initial load: fetch a cool example profile
  initEventListeners();
  fetchGitHubUser('octocat');
</script>
</body>
</html>
