<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>StudyGenie Tasks | Smart To-Do List with LocalStorage</title>
  <!-- Google Fonts + modern font -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
  <!-- Font Awesome 6 (free icons) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      padding: 2rem 1.5rem;
      position: relative;
    }

    /* background decorative circles */
    body::before {
      content: '';
      position: fixed;
      top: -20%;
      right: -10%;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(255,255,255,0.15), transparent);
      border-radius: 50%;
      pointer-events: none;
    }

    body::after {
      content: '';
      position: fixed;
      bottom: -15%;
      left: -5%;
      width: 350px;
      height: 350px;
      background: radial-gradient(circle, rgba(255,255,255,0.1), transparent);
      border-radius: 50%;
      pointer-events: none;
    }

    /* main app container */
    .app-container {
      max-width: 750px;
      margin: 0 auto;
      background: rgba(255, 255, 255, 0.97);
      backdrop-filter: blur(2px);
      border-radius: 48px;
      box-shadow: 0 30px 55px rgba(0, 0, 0, 0.2), 0 0 0 1px rgba(255,255,255,0.3);
      overflow: hidden;
      transition: transform 0.2s;
    }

    /* header with gradient */
    .app-header {
      background: linear-gradient(135deg, #3A0CA3, #6C2BD9);
      padding: 2rem 2rem 1.8rem;
      text-align: center;
      color: white;
    }

    .app-header h1 {
      font-size: 2rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
    }

    .app-header p {
      opacity: 0.9;
      margin-top: 8px;
      font-size: 0.9rem;
    }

    /* stats row */
    .stats-bar {
      display: flex;
      justify-content: space-between;
      background: rgba(255,255,255,0.12);
      margin-top: 1rem;
      padding: 0.8rem 1.2rem;
      border-radius: 60px;
      font-size: 0.85rem;
      font-weight: 500;
    }

    /* task input area */
    .task-input-section {
      padding: 2rem 2rem 1rem;
      background: white;
    }

    .input-group {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .task-input {
      flex: 1;
      padding: 1rem 1.2rem;
      border: 2px solid #e2e8f0;
      border-radius: 48px;
      font-size: 1rem;
      font-family: 'Inter', sans-serif;
      transition: all 0.2s;
      outline: none;
      background: #fefefe;
    }

    .task-input:focus {
      border-color: #6C2BD9;
      box-shadow: 0 0 0 3px rgba(108, 43, 217, 0.2);
    }

    .add-btn {
      background: linear-gradient(135deg, #6C2BD9, #3A0CA3);
      border: none;
      padding: 0 1.8rem;
      border-radius: 48px;
      color: white;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: 'Inter', sans-serif;
    }

    .add-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px -5px rgba(108, 43, 217, 0.4);
    }

    /* filters */
    .filters {
      display: flex;
      gap: 1rem;
      margin: 1.5rem 2rem 0.5rem;
      flex-wrap: wrap;
      border-bottom: 1px solid #edf2f7;
      padding-bottom: 0.8rem;
    }

    .filter-btn {
      background: transparent;
      border: none;
      padding: 0.5rem 1rem;
      font-weight: 600;
      font-size: 0.85rem;
      border-radius: 40px;
      cursor: pointer;
      transition: all 0.2s;
      color: #4a5568;
      font-family: inherit;
    }

    .filter-btn.active {
      background: #6C2BD9;
      color: white;
      box-shadow: 0 4px 10px rgba(108,43,217,0.2);
    }

    .filter-btn:hover:not(.active) {
      background: #f1f5f9;
    }

    /* task list container */
    .task-list-container {
      padding: 0 2rem 2rem;
      max-height: 450px;
      overflow-y: auto;
    }

    .task-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: #ffffff;
      padding: 1rem 1.2rem;
      margin-bottom: 12px;
      border-radius: 28px;
      transition: all 0.25s ease;
      border: 1px solid #edf2f7;
      box-shadow: 0 2px 6px rgba(0,0,0,0.02);
      animation: fadeSlide 0.2s ease;
    }

    @keyframes fadeSlide {
      from {
        opacity: 0;
        transform: translateX(-8px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .task-item:hover {
      transform: translateX(4px);
      border-color: #d9c9ff;
      box-shadow: 0 8px 18px -8px rgba(0,0,0,0.08);
    }

    .task-left {
      display: flex;
      align-items: center;
      gap: 14px;
      flex: 1;
    }

    .task-checkbox {
      width: 22px;
      height: 22px;
      cursor: pointer;
      accent-color: #6C2BD9;
      transition: transform 0.1s;
    }

    .task-checkbox:hover {
      transform: scale(1.05);
    }

    .task-text {
      font-size: 1rem;
      font-weight: 500;
      color: #1e293b;
      word-break: break-word;
      transition: all 0.2s;
    }

    .completed-task {
      text-decoration: line-through;
      color: #94a3b8;
    }

    .task-actions {
      display: flex;
      gap: 12px;
      align-items: center;
    }

    .edit-btn, .delete-btn {
      background: transparent;
      border: none;
      font-size: 1.1rem;
      cursor: pointer;
      padding: 6px;
      border-radius: 40px;
      transition: all 0.2s;
      width: 32px;
      height: 32px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .edit-btn {
      color: #3b82f6;
    }

    .edit-btn:hover {
      background: #eff6ff;
      transform: scale(1.05);
    }

    .delete-btn {
      color: #ef4444;
    }

    .delete-btn:hover {
      background: #fef2f2;
      transform: scale(1.05);
    }

    /* empty state */
    .empty-state {
      text-align: center;
      padding: 3rem 1rem;
      color: #94a3b8;
    }

    .empty-state i {
      font-size: 3rem;
      margin-bottom: 1rem;
      opacity: 0.5;
    }

    /* edit inline input */
    .edit-input {
      flex: 1;
      padding: 8px 12px;
      border: 2px solid #6C2BD9;
      border-radius: 32px;
      font-family: inherit;
      font-size: 0.95rem;
      outline: none;
    }

    /* responsive */
    @media (max-width: 600px) {
      body {
        padding: 1rem;
      }
      .app-header h1 {
        font-size: 1.5rem;
      }
      .task-input-section {
        padding: 1.5rem;
      }
      .input-group {
        flex-direction: column;
      }
      .add-btn {
        justify-content: center;
        padding: 0.9rem;
      }
      .task-list-container {
        padding: 0 1.2rem 1.5rem;
      }
      .filters {
        margin: 1rem 1.2rem 0.2rem;
      }
      .task-item {
        padding: 0.9rem;
      }
    }
  </style>
</head>
<body>

<div class="app-container">
  <div class="app-header">
    <h1><i class="fas fa-check-circle"></i> StudyGenie Tasks</h1>
    <p>Organize your study goals & daily tasks — saved automatically</p>
    <div class="stats-bar">
      <span><i class="fas fa-tasks"></i> Total: <span id="totalCount">0</span></span>
      <span><i class="fas fa-check"></i> Completed: <span id="completedCount">0</span></span>
      <span><i class="fas fa-hourglass-half"></i> Pending: <span id="pendingCount">0</span></span>
    </div>
  </div>

  <div class="task-input-section">
    <div class="input-group">
      <input type="text" id="taskInput" class="task-input" placeholder="Write a new task... e.g., Finish math homework" autocomplete="off">
      <button id="addTaskBtn" class="add-btn"><i class="fas fa-plus-circle"></i> Add Task</button>
    </div>
  </div>

  <div class="filters">
    <button class="filter-btn active" data-filter="all">All</button>
    <button class="filter-btn" data-filter="pending">Pending</button>
    <button class="filter-btn" data-filter="completed">Completed</button>
  </div>

  <div class="task-list-container" id="taskListContainer">
    <!-- dynamic tasks will render here -->
    <div class="empty-state" id="emptyStatePlaceholder">
      <i class="fas fa-clipboard-list"></i>
      <p>No tasks yet. Add your first task above ✨</p>
    </div>
    <div id="tasksWrapper"></div>
  </div>
</div>

<script>
  // ---------- TASK MODEL ----------
  let tasks = [];     // each task: { id, text, completed }

  // Load from localStorage
  function loadTasksFromStorage() {
    const stored = localStorage.getItem('studyGenieTasks');
    if (stored) {
      try {
        tasks = JSON.parse(stored);
      } catch(e) { tasks = []; }
    }
    if (!tasks.length) {
      // sample default tasks to showcase UI
      tasks = [
        { id: Date.now() + 1, text: 'Review AI notes for exam', completed: false },
        { id: Date.now() + 2, text: 'Complete calculus assignment', completed: true },
        { id: Date.now() + 3, text: 'Practice coding challenges', completed: false }
      ];
    }
  }

  // Save to localStorage
  function saveTasksToStorage() {
    localStorage.setItem('studyGenieTasks', JSON.stringify(tasks));
  }

  // Helper: update stats
  function updateStats() {
    const total = tasks.length;
    const completed = tasks.filter(t => t.completed).length;
    const pending = total - completed;
    document.getElementById('totalCount').innerText = total;
    document.getElementById('completedCount').innerText = completed;
    document.getElementById('pendingCount').innerText = pending;
  }

  // current filter: 'all', 'pending', 'completed'
  let currentFilter = 'all';

  // Render tasks based on currentFilter and optional inline edit mode
  let editingTaskId = null;   // track if any task is in edit mode (to avoid conflicts)

  function renderTasks() {
    const wrapper = document.getElementById('tasksWrapper');
    const emptyPlaceholder = document.getElementById('emptyStatePlaceholder');
    
    let filteredTasks = tasks.filter(task => {
      if (currentFilter === 'pending') return !task.completed;
      if (currentFilter === 'completed') return task.completed;
      return true;
    });

    if (filteredTasks.length === 0) {
      wrapper.innerHTML = '';
      emptyPlaceholder.style.display = 'block';
      updateStats();
      return;
    }
    
    emptyPlaceholder.style.display = 'none';
    
    // render each task
    wrapper.innerHTML = filteredTasks.map(task => {
      // if this task is being edited, render inline edit input
      if (editingTaskId === task.id) {
        return `
          <div class="task-item" data-task-id="${task.id}">
            <div class="task-left" style="flex:1;">
              <input type="text" id="edit-input-${task.id}" class="edit-input" value="${escapeHtml(task.text)}" autofocus>
            </div>
            <div class="task-actions">
              <button class="edit-btn save-edit-btn" data-id="${task.id}" title="Save"><i class="fas fa-save"></i></button>
              <button class="delete-btn cancel-edit-btn" data-id="${task.id}" title="Cancel"><i class="fas fa-times"></i></button>
            </div>
          </div>
        `;
      } else {
        // normal display
        const checkedAttr = task.completed ? 'checked' : '';
        const completedClass = task.completed ? 'completed-task' : '';
        return `
          <div class="task-item" data-task-id="${task.id}">
            <div class="task-left">
              <input type="checkbox" class="task-checkbox" data-id="${task.id}" ${checkedAttr}>
              <span class="task-text ${completedClass}">${escapeHtml(task.text)}</span>
            </div>
            <div class="task-actions">
              <button class="edit-btn" data-id="${task.id}" title="Edit"><i class="fas fa-pen"></i></button>
              <button class="delete-btn" data-id="${task.id}" title="Delete"><i class="fas fa-trash-alt"></i></button>
            </div>
          </div>
        `;
      }
    }).join('');
    
    updateStats();
    attachTaskEventListeners();
  }

  // helper to escape HTML to prevent XSS
  function escapeHtml(str) {
    return str.replace(/[&<>]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    }).replace(/[\uD800-\uDBFF][\uDC00-\uDFFF]/g, function(c) {
      return c;
    });
  }

  // attach dynamic listeners after render
  function attachTaskEventListeners() {
    // checkboxes
    document.querySelectorAll('.task-checkbox').forEach(cb => {
      cb.removeEventListener('change', handleCheckboxChange);
      cb.addEventListener('change', handleCheckboxChange);
    });
    
    // delete buttons
    document.querySelectorAll('.delete-btn:not(.cancel-edit-btn)').forEach(btn => {
      btn.removeEventListener('click', handleDelete);
      btn.addEventListener('click', handleDelete);
    });
    
    // edit buttons (normal edit)
    document.querySelectorAll('.edit-btn:not(.save-edit-btn)').forEach(btn => {
      btn.removeEventListener('click', handleEditClick);
      btn.addEventListener('click', handleEditClick);
    });
    
    // save edit & cancel edit (inline editing)
    document.querySelectorAll('.save-edit-btn').forEach(btn => {
      btn.removeEventListener('click', handleSaveEdit);
      btn.addEventListener('click', handleSaveEdit);
    });
    document.querySelectorAll('.cancel-edit-btn').forEach(btn => {
      btn.removeEventListener('click', handleCancelEdit);
      btn.addEventListener('click', handleCancelEdit);
    });
  }
  
  // checkbox change handler
  function handleCheckboxChange(e) {
    const taskId = parseInt(e.target.getAttribute('data-id'));
    const task = tasks.find(t => t.id === taskId);
    if (task) {
      task.completed = e.target.checked;
      saveTasksToStorage();
      renderTasks();  // re-render to reflect filter change & stats
    }
  }
  
  // delete handler
  function handleDelete(e) {
    const btn = e.currentTarget;
    const taskId = parseInt(btn.getAttribute('data-id'));
    tasks = tasks.filter(t => t.id !== taskId);
    // if we were editing that specific task, clear editing mode
    if (editingTaskId === taskId) editingTaskId = null;
    saveTasksToStorage();
    renderTasks();
  }
  
  // edit click: set editing mode
  function handleEditClick(e) {
    const btn = e.currentTarget;
    const taskId = parseInt(btn.getAttribute('data-id'));
    // if currently editing another task, first cancel it without saving changes
    if (editingTaskId !== null && editingTaskId !== taskId) {
      // discard previous edit mode
      editingTaskId = null;
      renderTasks();
      // after re-render, trigger edit again with small delay
      setTimeout(() => {
        const newBtn = document.querySelector(`.edit-btn[data-id="${taskId}"]:not(.save-edit-btn)`);
        if (newBtn) newBtn.click();
      }, 30);
      return;
    }
    editingTaskId = taskId;
    renderTasks();
    // focus the input after render
    setTimeout(() => {
      const editInput = document.getElementById(`edit-input-${taskId}`);
      if (editInput) {
        editInput.focus();
        editInput.select();
      }
    }, 20);
  }
  
  // save edited task
  function handleSaveEdit(e) {
    const btn = e.currentTarget;
    const taskId = parseInt(btn.getAttribute('data-id'));
    const editInput = document.getElementById(`edit-input-${taskId}`);
    if (editInput) {
      const newText = editInput.value.trim();
      if (newText !== "") {
        const task = tasks.find(t => t.id === taskId);
        if (task) {
          task.text = newText;
          saveTasksToStorage();
        }
      }
    }
    editingTaskId = null;
    renderTasks();
  }
  
  function handleCancelEdit(e) {
    const btn = e.currentTarget;
    const taskId = parseInt(btn.getAttribute('data-id'));
    if (editingTaskId === taskId) {
      editingTaskId = null;
      renderTasks();
    }
  }
  
  // add new task
  function addNewTask() {
    const inputEl = document.getElementById('taskInput');
    const taskText = inputEl.value.trim();
    if (taskText === "") {
      // subtle alert replacement with visual feedback
      const addBtn = document.getElementById('addTaskBtn');
      addBtn.style.transform = 'shake 0.3s';
      setTimeout(() => { addBtn.style.transform = ''; }, 300);
      alert("Please enter a task 😊");
      return;
    }
    const newTask = {
      id: Date.now(),
      text: taskText,
      completed: false
    };
    tasks.unshift(newTask);  // newest on top
    saveTasksToStorage();
    inputEl.value = "";
    // reset filter to 'all' so user sees new task
    if (currentFilter !== 'all') {
      currentFilter = 'all';
      document.querySelectorAll('.filter-btn').forEach(btn => {
        if (btn.getAttribute('data-filter') === 'all') btn.classList.add('active');
        else btn.classList.remove('active');
      });
    }
    renderTasks();
    // scroll to top of list
    const container = document.getElementById('taskListContainer');
    if (container) container.scrollTop = 0;
  }
  
  // filter change
  function setFilter(filter) {
    currentFilter = filter;
    // update active button style
    document.querySelectorAll('.filter-btn').forEach(btn => {
      const btnFilter = btn.getAttribute('data-filter');
      if (btnFilter === filter) btn.classList.add('active');
      else btn.classList.remove('active');
    });
    // if there's any pending inline edit, cancel it
    if (editingTaskId !== null) {
      editingTaskId = null;
    }
    renderTasks();
  }
  
  // event binding for filters and add button
  function bindGlobalEvents() {
    const addBtn = document.getElementById('addTaskBtn');
    addBtn.addEventListener('click', addNewTask);
    const taskInputField = document.getElementById('taskInput');
    taskInputField.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') addNewTask();
    });
    
    const filterBtns = document.querySelectorAll('.filter-btn');
    filterBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const filterValue = btn.getAttribute('data-filter');
        setFilter(filterValue);
      });
    });
  }
  
  // initialisation
  function init() {
    loadTasksFromStorage();
    bindGlobalEvents();
    renderTasks();
  }
  
  init();
</script>
</body>
</html>
