<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>StudyGenie | Responsive Navigation Bar Demo</title>
  <!-- Google Fonts + modern font stack -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
  <!-- Font Awesome 6 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: linear-gradient(135deg, #f5f7ff 0%, #e9eefc 100%);
      min-height: 100vh;
    }

    /* ----- MODERN RESPONSIVE NAVIGATION BAR ----- */
    .navbar {
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(10px);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
      position: sticky;
      top: 0;
      z-index: 1000;
      border-bottom: 1px solid rgba(108, 43, 217, 0.1);
    }

    .nav-container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1.5rem;
    }

    /* Logo / Brand */
    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      font-weight: 800;
      font-size: 1.6rem;
      background: linear-gradient(135deg, #3A0CA3, #6C2BD9);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      transition: opacity 0.2s;
    }

    .logo i {
      background: linear-gradient(135deg, #6C2BD9, #3A0CA3);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      font-size: 1.7rem;
    }

    .logo:hover {
      opacity: 0.85;
    }

    /* Desktop Menu */
    .nav-menu {
      display: flex;
      align-items: center;
      gap: 2rem;
      list-style: none;
    }

    .nav-item {
      list-style: none;
    }

    .nav-link {
      text-decoration: none;
      color: #1e293b;
      font-weight: 500;
      font-size: 1rem;
      transition: all 0.2s ease;
      padding: 0.5rem 0;
      position: relative;
    }

    .nav-link:hover {
      color: #6C2BD9;
    }

    .nav-link::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 0;
      height: 2px;
      background: linear-gradient(90deg, #6C2BD9, #3A0CA3);
      transition: width 0.25s ease;
    }

    .nav-link:hover::after {
      width: 100%;
    }

    /* CTA button in nav */
    .nav-cta {
      background: linear-gradient(135deg, #6C2BD9, #3A0CA3);
      color: white !important;
      padding: 0.5rem 1.3rem;
      border-radius: 40px;
      font-weight: 600;
    }

    .nav-cta:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 14px rgba(108, 43, 217, 0.3);
      background: linear-gradient(135deg, #7e3af2, #4b12c2);
    }

    .nav-cta::after {
      display: none;
    }

    /* Hamburger menu (mobile) */
    .hamburger {
      display: none;
      flex-direction: column;
      cursor: pointer;
      background: transparent;
      border: none;
      gap: 6px;
      padding: 6px;
      z-index: 1001;
    }

    .bar {
      width: 28px;
      height: 2.5px;
      background-color: #1e293b;
      transition: all 0.3s ease;
      border-radius: 10px;
    }

    /* Active state for hamburger (X icon) */
    .hamburger.active .bar:nth-child(1) {
      transform: translateY(8.5px) rotate(45deg);
    }

    .hamburger.active .bar:nth-child(2) {
      opacity: 0;
    }

    .hamburger.active .bar:nth-child(3) {
      transform: translateY(-8.5px) rotate(-45deg);
    }

    /* Responsive Breakpoint */
    @media (max-width: 768px) {
      .nav-container {
        padding: 0.9rem 1.5rem;
      }

      .hamburger {
        display: flex;
      }

      .nav-menu {
        position: fixed;
        left: -100%;
        top: 70px;
        flex-direction: column;
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(12px);
        width: 100%;
        text-align: center;
        transition: 0.35s cubic-bezier(0.2, 0.9, 0.4, 1.1);
        box-shadow: 0 20px 30px -10px rgba(0, 0, 0, 0.1);
        padding: 2rem 1rem;
        gap: 1.8rem;
        border-radius: 0 0 28px 28px;
        z-index: 999;
      }

      .nav-menu.active {
        left: 0;
      }

      .nav-link {
        font-size: 1.1rem;
        padding: 0.5rem;
        display: inline-block;
      }

      .nav-cta {
        width: fit-content;
        margin: 0 auto;
      }
    }

    /* Additional page content styling for demonstration */
    .hero-demo {
      max-width: 1100px;
      margin: 3rem auto;
      padding: 2rem;
      text-align: center;
    }

    .hero-demo h1 {
      font-size: 2.8rem;
      background: linear-gradient(135deg, #0f172a, #4c1d95);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      margin-bottom: 1rem;
    }

    .cards-demo {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 2rem;
      margin-top: 3rem;
    }

    .demo-card {
      background: white;
      padding: 2rem;
      border-radius: 32px;
      box-shadow: 0 12px 25px -12px rgba(0,0,0,0.08);
      transition: transform 0.2s;
    }

    .demo-card:hover {
      transform: translateY(-6px);
    }

    footer {
      text-align: center;
      padding: 2rem;
      color: #5b6e8c;
      margin-top: 3rem;
      border-top: 1px solid rgba(0,0,0,0.05);
    }

    @media (max-width: 480px) {
      .hero-demo h1 {
        font-size: 1.8rem;
      }
      .nav-container {
        padding: 0.7rem 1.2rem;
      }
    }
  </style>
</head>
<body>

  <!-- ========== RESPONSIVE NAVIGATION BAR ========== -->
  <nav class="navbar">
    <div class="nav-container">
      <!-- Logo / Brand -->
      <a href="#" class="logo">
        <i class="fas fa-brain"></i>
        <span>StudyGenie</span>
      </a>

      <!-- Hamburger Menu Button (mobile toggle) -->
      <button class="hamburger" id="hamburgerBtn" aria-label="Menu">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>

      <!-- Navigation Menu Items -->
      <ul class="nav-menu" id="navMenu">
        <li class="nav-item"><a href="#" class="nav-link">Home</a></li>
        <li class="nav-item"><a href="#" class="nav-link">Features</a></li>
        <li class="nav-item"><a href="#" class="nav-link">Pricing</a></li>
        <li class="nav-item"><a href="#" class="nav-link">Testimonials</a></li>
        <li class="nav-item"><a href="#" class="nav-link nav-cta"><i class="fas fa-rocket"></i> Get Started</a></li>
      </ul>
    </div>
  </nav>

  <!-- ========== DEMO CONTENT (to show scrolling & nav behavior) ========== -->
  <main>
    <div class="hero-demo">
      <h1>Study Smarter with AI-Powered Learning</h1>
      <p style="font-size: 1.2rem; color: #334155; max-width: 700px; margin: 1rem auto;">Experience seamless navigation — resize your browser or tap the hamburger menu on mobile.</p>
      
      <div class="cards-demo">
        <div class="demo-card">
          <i class="fas fa-robot" style="font-size: 2.5rem; color: #6C2BD9;"></i>
          <h3 style="margin: 1rem 0 0.5rem;">AI Doubt Solver</h3>
          <p>Instant answers to any subject question, 24/7.</p>
        </div>
        <div class="demo-card">
          <i class="fas fa-book-open" style="font-size: 2.5rem; color: #6C2BD9;"></i>
          <h3 style="margin: 1rem 0 0.5rem;">Smart Notes</h3>
          <p>Generate study notes from any content automatically.</p>
        </div>
        <div class="demo-card">
          <i class="fas fa-chart-line" style="font-size: 2.5rem; color: #6C2BD9;"></i>
          <h3 style="margin: 1rem 0 0.5rem;">Progress Tracking</h3>
          <p>Monitor learning performance with analytics.</p>
        </div>
      </div>
    </div>
    <footer>
      <p>© 2026 StudyGenie — Responsive Navigation Demo | Smooth mobile & desktop experience</p>
    </footer>
  </main>

  <!-- ========== JAVASCRIPT FOR HAMBURGER TOGGLE (WITH SMOOTH INTERACTION) ========== -->
  <script>
    (function() {
      // Get DOM elements
      const hamburgerBtn = document.getElementById('hamburgerBtn');
      const navMenu = document.getElementById('navMenu');
      
      // Function to toggle menu
      function toggleMenu() {
        hamburgerBtn.classList.toggle('active');
        navMenu.classList.toggle('active');
        // Optional: prevent body scrolling when menu is open on mobile
        if (navMenu.classList.contains('active')) {
          document.body.style.overflow = 'hidden';
        } else {
          document.body.style.overflow = '';
        }
      }
      
      // Click event for hamburger button
      if (hamburgerBtn) {
        hamburgerBtn.addEventListener('click', toggleMenu);
      }
      
      // Close menu when a nav link is clicked (improves UX)
      const navLinks = document.querySelectorAll('.nav-link');
      navLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          // If menu is open on mobile, close it after clicking a link
          if (navMenu.classList.contains('active')) {
            toggleMenu();
          }
          // Optional: you can add smooth scroll logic here if needed
        });
      });
      
      // Close menu when window is resized above 768px (in case it's stuck open)
      window.addEventListener('resize', () => {
        if (window.innerWidth > 768) {
          if (navMenu.classList.contains('active')) {
            hamburgerBtn.classList.remove('active');
            navMenu.classList.remove('active');
            document.body.style.overflow = '';
          }
        }
      });
      
      // optional: close menu when clicking outside (enhanced mobile experience)
      document.addEventListener('click', (event) => {
        const isClickInsideNav = navMenu.contains(event.target);
        const isClickOnHamburger = hamburgerBtn.contains(event.target);
        
        if (navMenu.classList.contains('active') && !isClickInsideNav && !isClickOnHamburger) {
          toggleMenu();
        }
      });
    })();
  </script>
</body>
</html>
